# ── AppGen Root Environment Variables (Docker & Local Config) ──

# Database Configuration
DB_NAME=ai_app_generator
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_SECURE_PASSWORD

# Connection pooling limits
DB_POOL_MAX=20

# JWT Authentication Config
# Generate a secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=YOUR_SECURE_RANDOM_JWT_SECRET
JWT_EXPIRES=7d

# Networking & Ports
# Ports exposed to the host machine
FRONTEND_PORT=80
BACKEND_PORT=4000

# CORS settings
FRONTEND_URL=http://localhost
